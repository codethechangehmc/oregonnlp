# BERTopic pre-trained model path (relative to backend/)
BERTOPIC_MODEL_PATH=../models/fishing_survey_bertopic

# SQLite database path (relative to backend/)
DATABASE_PATH=./data/app.db

# OpenAI API key for topic labeling (leave empty to use keyword fallback)
OPENAI_API_KEY=

# LLM provider: "openai" or "local"
LLM_PROVIDER=openai

# Local LLM model name (only used when LLM_PROVIDER=local)
LOCAL_LLM_MODEL=flan-t5
